PROBLEMES WITH TABLES
1/  Suppose we have table products:
| id | price |
| -- | ----- |
| 1  | 100   |
| 2  | 200   |
  DELIMITER //

CREATE FUNCTION getPrice(pid INT)
RETURNS INT
DETERMINISTIC
BEGIN
   DECLARE p INT;

   SELECT price INTO p
   FROM products
   WHERE id = pid;

   RETURN p;
END //

DELIMITER ;

