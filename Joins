1/INNER JOIN
SELECT tablename1,pramerykey ,tablename2.pramerykey
FROM   table1 INNER JOIN table2 ON 
 table1.id=table2.table2_id
//LOOK AT IMAGE NAMED INNER JOINT

2/LEFT JOIN
SELECT tablename1,pramerykey ,tablename2.pramerykey
FROM   table1 LEFT JOIN table2 ON 
 table1.id=table2.table2_id
//LOOK AT IMAGE NAMED LEFT JOINT
3/RIGHT
SELECT tablename1,pramerykey ,tablename2.pramerykey
FROM   table1 RIGHT JOIN table2 ON 
 table1.id=table2.table2_id
//LOOK AT IMAGE NAMED RIGHT JOINT

3/OUTER JOIN(LEFT+RIGHT)
SELECT tablename1,pramerykey ,tablename2.pramerykey
FROM   table1 LEFT JOIN table2 ON 
 table1.id=table2.table2_id
UNION 
SELECT tablename1,pramerykey ,tablename2.pramerykey
FROM   table1 RIGHT JOIN table2 ON 
 table1.id=table2.table2_id
//LOOK AT IMAGE NAMED OUTER JOIN(METHODE1)


SELECT tablename1,pramerykey ,tablename2.pramerykey
FROM   table1 FULL OUTER JOIN table2 ON 
 table1.id=table2.table2_id
//LOOK AT IMAGE NAMED OUTER JOIN(METHODE2)
