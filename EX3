2/ retourner le code du salarié utilisant une voiture

 DELEMETER$$
  creat function   code(
   vmarticul varche(50),
   vdate date)
   returne int 
   deterministic
    begin 
    declar codes int
     selecet code into codes   
     from voiture
     where   matricul = vmatrucil 
     and date=vdate;
     retune codes;
    end$$
      DELEMETER;
  
     
