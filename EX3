Prevent assigning car to employee from: informatique

 DELEMETER$$
  creat trigger preventa
  before insert 
  on Utilisation
  for each row
   begin 
   declar e  varche (50)
   select service into  e
   from  salarie
   where codesal=new.codesal;
   if   e = 'informatique' then 
    singal sqlstate '45000'
    set message_text =' Prevent assigning car to employee from: informatique '
   end$$
    DELEMETER;

